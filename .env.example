# ─── FTI Trading App — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values

# Database (leave as-is for SQLite dev, or set PostgreSQL URL for production)
DATABASE_URL=sqlite:///./fti_trading.db

# Security — CHANGE THIS to a random 32+ char string before deploying
SECRET_KEY=change-this-to-a-long-random-secret-key-minimum-32-chars

# App URL (used in emails for links)
APP_URL=http://localhost:8000

# ─── Email Config (Gmail SMTP example) ──────────────────────────────────────
# For Gmail: enable 2FA, generate an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=your@gmail.com

# ─── OR use SendGrid (free tier: 100 emails/day) ─────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASSWORD=your-sendgrid-api-key
# FROM_EMAIL=signals@yourdomain.com
