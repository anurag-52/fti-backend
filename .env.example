# ─── FTI Trading App — Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your values

# Database (leave as-is for SQLite dev, set PostgreSQL URL for Railway/production)
DATABASE_URL=sqlite:///./fti_trading.db

# Security — CHANGE THIS to a random 32+ char string before deploying
SECRET_KEY=change-this-to-a-long-random-secret-key-minimum-32-chars

# App URL (used in email links — set to your Railway/Vercel domain in production)
APP_URL=http://localhost:8000

# ─── Email — Brevo (Sendinblue) API ─────────────────────────────────────────
# The app uses Brevo's transactional email API (free tier: 300 emails/day)
# 1. Create account at https://www.brevo.com
# 2. Go to SMTP & API → API Keys → Generate a new API key
# 3. Paste it below
BREVO_API_KEY=your-brevo-api-key-here

# The sender email address (must be verified in your Brevo account)
FROM_EMAIL=signals@yourdomain.com
